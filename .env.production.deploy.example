# ============================================================
# BonSync — Production Environment Variables for Cloud Run
# ============================================================
# RENAME file ini jadi .env.production.deploy (bukan .env.production)
# agar tidak ter-commit ke git secara tidak sengaja.
#
# File ini TIDAK akan ikut ke Docker image (sudah ada di .dockerignore).
# Digunakan oleh: deploy-cloudbuild.sh
# ============================================================

# ── Google Cloud Project ────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast2

# ── Database (Supabase PostgreSQL) ──────────────────────────
# Dari: Supabase Dashboard → Settings → Database → Connection string → URI
# Pilih mode: Transaction (untuk serverless) atau Session
# Tambahkan ?sslmode=require di akhir URL
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# ── Supabase Auth ───────────────────────────────────────────
# Dari: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── App URL (Cloud Run URL) ─────────────────────────────────
# STEP 1: Deploy dulu dengan placeholder, lalu update ke URL asli setelah dapat URL
# STEP 2: Set URL ini di Supabase → Authentication → URL Configuration → Site URL
# STEP 3: Tambahkan {URL}/auth/callback ke Allowed Redirect URLs
NEXT_PUBLIC_SITE_URL=https://bonsync-app-XXXXXXXXXX-as.a.run.app

# ── Google Gemini API ───────────────────────────────────────
# Dari: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy...
