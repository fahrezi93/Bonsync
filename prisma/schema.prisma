generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExpenseSource {
  MANUAL
  QUICK_RECEIPT
  SPLIT_BILL
}

enum ReceiptMode {
  QUICK
  SPLIT
}

enum ReceiptItemOwner {
  SELF
  OTHER
}

model MonthlyBudget {
  id          String   @id @default(uuid())
  userId      String   @default("legacy")
  limitAmount Float
  month       String
  latestRoast String?
  createdAt   DateTime @default(now())

  @@unique([userId, month])
  @@index([userId])
}

model Receipt {
  id                  String        @id @default(uuid())
  userId              String        @default("legacy")
  merchantName        String
  subtotalAmount      Float
  discountAmount      Float         @default(0)
  taxAmount           Float         @default(0)
  serviceChargeAmount Float         @default(0)
  totalAmount         Float
  mode                ReceiptMode
  createdAt           DateTime      @default(now())
  items               ReceiptItem[]
  expenses            Expense[]

  @@index([userId])
}

model ReceiptItem {
  id        String           @id @default(uuid())
  receiptId String
  itemName  String
  price     Float
  ownerType ReceiptItemOwner
  receipt   Receipt          @relation(fields: [receiptId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String   @id @default(uuid())
  userId      String   @default("legacy")
  description String?
  totalAmount Float
  category    String
  aiAdvice    String
  isSplitBill Boolean  @default(false)
  source      ExpenseSource @default(MANUAL)
  receiptId   String?
  receipt     Receipt? @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  date        DateTime @default(now())

  @@index([userId, date])
}
